# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
.python-version

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets and local environment
.env
# The Module 10 hermetic fixture ships an intentional, documented-non-secret .env
# (all values fail real-provider validation - see the fixture NOTICE); it must be
# tracked so the offline security exercises can read it on a fresh clone.
!tests/fixtures/m10/minefield-mirror/.env

# coursectl clones target repositories here (spec 10.5); anchored to the
# repo root so Go packages like coursectl/internal/workspace stay tracked
/workspace/

# scripts/bootstrap.{sh,ps1} extract the coursectl binary here
/bin/

# Execution traces are local artifacts, except the committed examples and the
# recorded course fixtures shipped with a module (e.g. Module 2 replay trace).
traces/*
!traces/examples/
!traces/m02/
!traces/m03/
!traces/m04/
!traces/m05/
!traces/m06/
!traces/m07/
!traces/m08/
!traces/m09/
!traces/m10/
